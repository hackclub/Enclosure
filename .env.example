# Frontend API base (Vite)
VITE_API_BASE=http://localhost:4000

# App/frontend URL used by auth redirects
FRONTEND_BASE_URL=http://localhost:5713

# Postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Hack Club Identity OAuth
HC_IDENTITY_CLIENT_ID=your_hc_identity_client_id
HC_IDENTITY_CLIENT_SECRET=your_hc_identity_client_secret

# Optional: override callback URL (non-production defaults to localhost callback in code)
# HC_IDENTITY_REDIRECT_URI=http://localhost:4000/api/auth/callback